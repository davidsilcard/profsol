DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=troque-esta-chave-por-uma-forte
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=profsol.moven.cloud
DJANGO_CSRF_TRUSTED_ORIGINS=https://profsol.moven.cloud
SITE_URL=https://profsol.moven.cloud
SITE_NAME=Prof. Sol Tricô & Crochê

YOUTUBE_CHANNEL_URL=https://www.youtube.com/@prof.sol.tricoecroche
YOUTUBE_SYNC_ON_DEMAND=true

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=contato@profsol.moven.cloud
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_HOST_USER=contato@profsol.moven.cloud
EMAIL_HOST_PASSWORD=troque-esta-senha
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
MERCADO_PAGO_PUBLIC_KEY=APP_USR-...
MERCADO_PAGO_WEBHOOK_SECRET=

DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
